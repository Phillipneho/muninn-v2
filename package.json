{
  "name": "muninn-v2",
  "version": "0.1.0",
  "description": "Memory as evolving reality - Zep-inspired bi-temporal knowledge graph",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "migrate": "psql $DATABASE_URL -f src/schema.sql",
    "migrate:local": "psql postgresql://muninn:muninn@localhost:5432/muninn_v2 -f src/schema.sql",
    "migrate:neon": "echo 'Set DATABASE_URL and run: psql $DATABASE_URL -f src/schema.sql'",
    "test": "tsx src/tests/",
    "mcp": "tsx src/mcp/server.ts",
    "setup:local": "./setup.sh local",
    "setup:neon": "./setup.sh neon"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "openai": "^4.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0"
  }
}