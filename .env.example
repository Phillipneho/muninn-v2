# Muninn v2 Database Configuration
# 
# Option 1: Neon (cloud, recommended for production)
# Create a new project at https://console.neon.tech or use existing
# DATABASE_URL=postgresql://username:password@ep-xxx.pooler.neon.tech/muninn?sslmode=require
#
# Option 2: Local PostgreSQL (development)
# DATABASE_URL=postgresql://muninn:muninn@localhost:5432/muninn
#
# Option 3: SQLite (local development, no setup)
# DATABASE_PATH=/path/to/muninn.db

# Embedding API (OpenAI) - set your own key
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Session secret for MCP
SESSION_SECRET=muninn-v2-dev-secret-change-in-production